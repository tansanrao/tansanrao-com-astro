---
interface Props {
  title: string;
  description: string;
  publishedDate: string;
  href: string;
  coverImg?: string;
  readingTime?: number;
}

const { title, description, publishedDate, href, coverImg, readingTime } = Astro.props;
---

<a href={href} class="block group">
  <article class="h-full rounded-lg border border-light-ui dark:border-dark-ui bg-light-bg dark:bg-dark-bg overflow-hidden transition-all duration-300 hover:border-light-bl dark:hover:border-dark-bl">
    <div class="relative h-48 overflow-hidden">
      {coverImg ? (
        <img 
          src={coverImg} 
          alt="" 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <div class="relative h-full w-full bg-light-bg-2 dark:bg-dark-bg-2">
          <div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#8C8C8C1A_1px,transparent_1px),linear-gradient(to_bottom,#8C8C8C1A_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#4F4F4F2E_1px,transparent_1px),linear-gradient(to_bottom,#4F4F4F2E_1px,transparent_1px)] bg-[size:14px_24px]">
            <div class="absolute inset-0 flex items-center justify-center p-6">
              <h2 class="text-2xl font-serif text-center font-bold text-light-tx dark:text-dark-tx">
                {title}
              </h2>
            </div>
          </div>
        </div>
      )}
    </div>
    <div class="p-6">
      {coverImg && (
        <h2 class="text-xl font-serif font-bold text-light-tx dark:text-dark-tx transition-colors duration-300 group-hover:text-light-bl dark:group-hover:text-dark-bl">
          {title}
        </h2>
      )}
      <p class="mt-2 text-light-tx-2 dark:text-dark-tx-2 line-clamp-3">
        {description}
      </p>
      <div class="mt-4 flex items-center gap-3 text-sm text-light-tx-3 dark:text-dark-tx-3">
        <time>
          Published on {publishedDate}
        </time>
        {readingTime && (
          <>
            <span>•</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>
    </div>
  </article>
</a> 