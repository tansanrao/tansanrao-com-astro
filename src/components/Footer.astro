---
const currentYear = new Date().getFullYear();

// Format the build date as DD MMM YYYY
const buildDate = new Date().toLocaleDateString('en-US', {
  day: '2-digit',
  month: 'short',
  year: 'numeric'
});

const socialLinks = {
  email: "mailto:tanujrao99@gmail.com",
  github: "https://github.com/tansanrao",
  linkedin: "https://linkedin.com/in/tansanrao",
  orcid: "https://orcid.org/0009-0008-1249-784X",
  rss: "/rss"
};
---

<footer class="w-full bg-light-bg-2 dark:bg-dark-bg border-t border-light-ui dark:border-dark-ui">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col items-center gap-4">
      <div class="flex items-center space-x-6">
        <a href={socialLinks.email} class="text-light-tx-2 dark:text-dark-tx-2 hover:text-light-tx dark:hover:text-dark-tx">
          <span class="sr-only">Email</span>
          <i class="fa-regular fa-envelope text-xl"></i>
        </a>
        <a href={socialLinks.github} class="text-light-tx-2 dark:text-dark-tx-2 hover:text-light-tx dark:hover:text-dark-tx">
          <span class="sr-only">GitHub</span>
          <i class="fa-brands fa-github text-xl"></i>
        </a>
        <a href={socialLinks.linkedin} class="text-light-tx-2 dark:text-dark-tx-2 hover:text-light-tx dark:hover:text-dark-tx">
          <span class="sr-only">LinkedIn</span>
          <i class="fa-brands fa-linkedin text-xl"></i>
        </a>
        <a href={socialLinks.orcid} class="text-light-tx-2 dark:text-dark-tx-2 hover:text-light-tx dark:hover:text-dark-tx">
          <span class="sr-only">ORCID</span>
          <i class="fa-brands fa-orcid text-xl"></i>
        </a>
        <a href={socialLinks.rss} class="text-light-tx-2 dark:text-dark-tx-2 hover:text-light-tx dark:hover:text-dark-tx">
          <span class="sr-only">RSS Feed</span>
          <i class="fa-solid fa-rss text-xl"></i>
        </a>
      </div>
      <div class="text-center text-light-tx-3 dark:text-dark-tx-3">
        <p>© {currentYear} Tanuj Ravi Rao. Except when otherwise noted, content licensed under <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="underline hover:text-light-tx dark:hover:text-dark-tx">CC-BY-SA 4.0</a>.</p>
        <p>Powered by <a href="https://astro.build" class="underline hover:text-light-tx dark:hover:text-dark-tx">Astro</a> and hosted on <a href="https://pages.cloudflare.com" class="underline hover:text-light-tx dark:hover:text-dark-tx">Cloudflare Pages</a>. Last updated: {buildDate}</p>
      </div>
    </div>
  </div>
</footer> 