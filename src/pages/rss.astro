---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const feeds = [
  {
    title: "All Content",
    description: "Everything from the blog and digital garden, including blog posts and notes",
    url: "/rss.xml",
    icon: "fa-solid fa-rss"
  },
  {
    title: "Blog Posts",
    description: "Long-form articles and blog posts only",
    url: "/blog.xml",
    icon: "fa-solid fa-newspaper"
  },
  {
    title: "Notes",
    description: "Digital garden notes and shorter content pieces",
    url: "/notes.xml",
    icon: "fa-solid fa-note-sticky"
  }
];

const readers = {
  hosted: [
    {
      name: "Feedly",
      description: "Popular web-based reader with excellent organization and mobile apps",
      icon: "fa-solid fa-globe",
      url: "https://feedly.com"
    },
    {
      name: "NewsBlur",
      description: "Feature-rich reader with powerful filtering and social features",
      icon: "fa-solid fa-newspaper",
      url: "https://newsblur.com"
    }
  ],
  selfHosted: [
    {
      name: "Miniflux",
      description: "Minimalist, lightweight reader focused on simplicity and speed",
      icon: "fa-solid fa-server",
      url: "https://miniflux.app"
    },
    {
      name: "FreshRSS",
      description: "Full-featured, extensible RSS aggregator with multi-user support",
      icon: "fa-solid fa-code",
      url: "https://freshrss.org"
    }
  ]
};
---

<BaseLayout
  title="RSS | Tanuj Ravi Rao"
  description="Subscribe to various RSS feeds from Tanuj Ravi Rao's website"
>
  <PageHeader
    title="RSS Feeds"
    subtitle="Subscribe to updates from this website using your favorite RSS reader"
  />

  <div class="prose dark:prose-invert max-w-none">
    <p class="text-lg">
      This website provides multiple RSS feeds to help you stay updated with new content. 
      Choose the feed that best matches your interests:
    </p>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {feeds.map(feed => (
        <article class="p-6 rounded-lg bg-light-bg-2 dark:bg-dark-bg-2 border border-light-ui dark:border-dark-ui hover:border-light-pu dark:hover:border-dark-pu transition-colors duration-200">
          <a href={feed.url} class="block group no-underline h-full flex flex-col">
            <div class="flex items-center gap-3">
              <i class={`${feed.icon} text-xl text-light-pu dark:text-dark-pu`}></i>
              <h2 class="text-2xl font-bold text-light-tx dark:text-dark-tx group-hover:text-light-pu dark:group-hover:text-dark-pu transition-colors duration-200">{feed.title}</h2>
            </div>
            <p class="mt-3 text-light-tx-2 dark:text-dark-tx-2 line-clamp-2">
              {feed.description}
            </p>
            <div class="mt-4 flex items-center text-light-pu dark:text-dark-pu mt-auto">
              <span class="text-sm font-medium no-underline">Subscribe</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 group-hover:translate-x-1 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
          </a>
        </article>
      ))}
    </div>

    <h2 class="mt-12 mb-4 text-2xl font-bold">What is RSS?</h2>
    <p>
      RSS (Really Simple Syndication) is a web feed technology that lets you subscribe to websites and get notified when they publish new content. 
      Instead of visiting multiple websites manually, RSS lets you receive updates automatically in an RSS reader of your choice.
    </p>

    <h2 class="mt-8 mb-4 text-2xl font-bold">Popular RSS Readers</h2>
    
    <h3 class="text-xl font-bold mb-3">Hosted Services</h3>
    <div class="grid gap-4 md:grid-cols-2 mb-6">
      {readers.hosted.map(reader => (
        <article class="p-6 rounded-lg bg-light-bg-2 dark:bg-dark-bg-2 border border-light-ui dark:border-dark-ui hover:border-light-pu dark:hover:border-dark-pu transition-colors duration-200">
          <a href={reader.url} target="_blank" rel="noopener noreferrer" class="block group no-underline h-full flex flex-col">
            <div class="flex items-center gap-3">
              <i class={`${reader.icon} text-xl text-light-pu dark:text-dark-pu`}></i>
              <h4 class="text-xl font-bold text-light-tx dark:text-dark-tx group-hover:text-light-pu dark:group-hover:text-dark-pu transition-colors duration-200">{reader.name}</h4>
            </div>
            <p class="mt-3 text-light-tx-2 dark:text-dark-tx-2 line-clamp-2">
              {reader.description}
            </p>
            <div class="mt-4 flex items-center text-light-pu dark:text-dark-pu mt-auto">
              <span class="text-sm font-medium no-underline">Visit website</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 group-hover:translate-x-1 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
          </a>
        </article>
      ))}
    </div>

    <h3 class="text-xl font-bold mb-3">Self-Hosted Options</h3>
    <div class="grid gap-4 md:grid-cols-2">
      {readers.selfHosted.map(reader => (
        <article class="p-6 rounded-lg bg-light-bg-2 dark:bg-dark-bg-2 border border-light-ui dark:border-dark-ui hover:border-light-pu dark:hover:border-dark-pu transition-colors duration-200">
          <a href={reader.url} target="_blank" rel="noopener noreferrer" class="block group no-underline h-full flex flex-col">
            <div class="flex items-center gap-3">
              <i class={`${reader.icon} text-xl text-light-pu dark:text-dark-pu`}></i>
              <h4 class="text-xl font-bold text-light-tx dark:text-dark-tx group-hover:text-light-pu dark:group-hover:text-dark-pu transition-colors duration-200">{reader.name}</h4>
            </div>
            <p class="mt-3 text-light-tx-2 dark:text-dark-tx-2 line-clamp-2">
              {reader.description}
            </p>
            <div class="mt-4 flex items-center text-light-pu dark:text-dark-pu mt-auto">
              <span class="text-sm font-medium no-underline">Visit website</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 group-hover:translate-x-1 transition-transform duration-200" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
          </a>
        </article>
      ))}
    </div>

    <h2 class="mt-8 mb-4 text-2xl font-bold">How to Subscribe</h2>
    <ol class="list-decimal pl-6">
      <li class="mb-2">Choose an RSS reader from the options above or use your preferred one.</li>
      <li class="mb-2">Copy the URL of the feed you want to subscribe to.</li>
      <li class="mb-2">In your RSS reader, look for an "Add Feed" or "Subscribe" button.</li>
      <li class="mb-2">Paste the feed URL and confirm the subscription.</li>
      <li>You'll now receive updates whenever new content is published!</li>
    </ol>
  </div>
</BaseLayout> 